# ============================================================
# CHATWOOT — VARIÁVEIS DE AMBIENTE
# ============================================================
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha todos os valores marcados com <PREENCHER>
# 3. Nunca suba o .env para o GitHub (já está no .gitignore)
# ============================================================

# ------------------------------------------------------------
# APLICAÇÃO
# ------------------------------------------------------------
FRONTEND_URL=https://<seu-dominio.com>          # ex: https://chat.cliente.com.br
SECRET_KEY_BASE=<PREENCHER>                     # gerar: openssl rand -hex 64

# ------------------------------------------------------------
# BANCO DE DADOS — PostgreSQL
# Use as mesmas credenciais nos dois campos abaixo
# ------------------------------------------------------------
POSTGRES_PASSWORD=<SENHA_FORTE>
DATABASE_URL=postgresql://chatwoot:<SENHA_FORTE>@postgres:5432/chatwoot

# ------------------------------------------------------------
# CACHE / FILAS — Redis
# Use a mesma senha nos dois campos abaixo
# ------------------------------------------------------------
REDIS_PASSWORD=<SENHA_FORTE_REDIS>
REDIS_URL=redis://:<SENHA_FORTE_REDIS>@redis:6379

# ------------------------------------------------------------
# E-MAIL (SMTP)
# Suporta: SendGrid, Mailgun, SES, Google Workspace, Outlook
# ------------------------------------------------------------
MAILER_SENDER_EMAIL=noreply@<seu-dominio.com>
SMTP_ADDRESS=<smtp.seudominio.com>
SMTP_PORT=587
SMTP_USERNAME=<usuario@seudominio.com>
SMTP_PASSWORD=<SENHA_SMTP>
SMTP_TLS=true
# SMTP_SSL=false                                # usar se porta 465

# ------------------------------------------------------------
# STORAGE — Hetzner Object Storage (produção)
# Painel Hetzner → Object Storage → Bucket → Manage → Access Keys
# Endpoint formato: https://<região>.your-objectstorage.com
# Regiões: fsn1 | nbg1 | hel1 | ash
# ------------------------------------------------------------
ACTIVE_STORAGE_SERVICE=amazon
AWS_ACCESS_KEY_ID=<HETZNER_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<HETZNER_SECRET_KEY>
AWS_S3_BUCKET_NAME=<nome-do-bucket>
AWS_S3_ENDPOINT=https://fsn1.your-objectstorage.com
AWS_S3_REGION=eu-central-1
AWS_S3_FORCE_PATH_STYLE=true

# Para desenvolvimento local, substitua ACTIVE_STORAGE_SERVICE:
# ACTIVE_STORAGE_SERVICE=local

# ------------------------------------------------------------
# CONFIGURAÇÕES GERAIS
# ------------------------------------------------------------
DEFAULT_LOCALE=pt_BR
ENABLE_ACCOUNT_SIGNUP=false                     # false = só super admin cria contas
LOG_LEVEL=info
LOG_SIZE=100                                    # MB
